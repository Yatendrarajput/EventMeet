# ─────────────────────────────────────────
# Server
# ─────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000/v1
CLIENT_URL=http://localhost:5173

# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
DATABASE_URL=postgresql://eventmeet:eventmeet_dev@localhost:5432/eventmeet_db

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────
# Email (AWS SES)
# ─────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=noreply@eventmeet.in

# ─────────────────────────────────────────
# AWS S3
# ─────────────────────────────────────────
S3_BUCKET_NAME=eventmeet-tickets
S3_PRESIGNED_URL_EXPIRES=3600

# ─────────────────────────────────────────
# Cloudinary
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─────────────────────────────────────────
# Razorpay
# ─────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─────────────────────────────────────────
# Tickets (HMAC QR signing)
# ─────────────────────────────────────────
TICKET_HMAC_SECRET=change_me_ticket_hmac_secret_min_32_chars

# ─────────────────────────────────────────
# Sentry (optional in dev)
# ─────────────────────────────────────────
SENTRY_DSN=
